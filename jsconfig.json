{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "checkJs": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": []
  },
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "public"
  ]
}